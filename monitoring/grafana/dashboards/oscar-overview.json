{
  "uid": "oscar-overview",
  "title": "Open OSCAR \u2014 Overview",
  "tags": ["oscar"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Management API",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [{ "refId": "A", "expr": "oscar_api_up", "legendFormat": "", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Accounts",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "oscar_users_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active Sessions",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "oscar_sessions_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Web API Keys",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "oscar_webapi_keys_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Chat Rooms",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "linear", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "expr": "oscar_chat_rooms_public_total", "legendFormat": "public", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "oscar_chat_rooms_private_total", "legendFormat": "private", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "API Scrape Duration (seconds)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "refId": "A", "expr": "oscar_scrape_duration_seconds", "legendFormat": "duration", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Directory Categories",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "refId": "A", "expr": "oscar_directory_categories_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Server Info",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 14 },
      "targets": [{ "refId": "A", "expr": "oscar_info", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" } }]
    }
  ]
}
